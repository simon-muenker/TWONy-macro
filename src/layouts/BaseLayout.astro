---
import "@styles/global.css";

import Header from "@layouts/partials/Header.astro";
import Footer from "@layouts/partials/Footer.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en" class="min-h-full min-w-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-full min-w-full bg-slate-100">
    <div class="fixed top-0 left-0 z-50 p-3 md:hidden">
      <span class="text-xl text-slate-300">
        <span class="font-bold lowercase">T<span class="text-blue-500">W</span>ON</span>y
        <span class="text-slate-400">(macro)</span>
      </span>
    </div>
   <div
      class="fixed top-0 left-0 z-50 hidden w-auto rounded-br-2xl bg-black/10 backdrop-blur-md md:block"
    >
      <Header />
    </div>
    <main class="relative h-screen w-screen">
      <slot />
    </main>
    <div
      class="fixed right-0 bottom-0 z-50 hidden w-auto rounded-tl-2xl bg-black/10 backdrop-blur-md md:block"
    >
      <Footer />
    </div>
  </body>
</html>